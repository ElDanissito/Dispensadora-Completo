# ============================================================================
# GRABI — variables de entorno de PRODUCCIÓN (EC2 + Docker Compose, ADR-021)
# ============================================================================
# Copia este archivo a `.env` EN LA EC2 y rellena los valores reales:
#     cp .env.example .env
#     nano .env
#     chmod 600 .env
# El `.env` real NUNCA se commitea (está en .gitignore). CLAUDE.md §4.
# docker-compose.prod.yml lo lee automáticamente (secretos + interpolación).
# ----------------------------------------------------------------------------

# --- Dominio / TLS (Caddy) --------------------------------------------------
# Dominio público de la máquina. Debe apuntar (registro DNS A) a la IP pública
# de la EC2 ANTES de levantar, o Caddy no podrá emitir el certificado.
DOMAIN=grabi.napi.lat

# --- Base de datos (Postgres interno) ---------------------------------------
# Contraseña del Postgres que corre como contenedor. Elige una fuerte.
# NO definas DATABASE_URL aquí: el compose la arma solo a partir de este valor
# (postgres://grabi:<POSTGRES_PASSWORD>@db:5432/grabi).
POSTGRES_PASSWORD=

# --- Panel admin (login del panel /admin) -----------------------------------
ADMIN_USER=admin
ADMIN_PASS=

# --- Firma del token (llave privada Ed25519) --------------------------------
# Base64 de la llave privada (la que genera `dsp keygen`). Sin ella el servidor
# arranca pero NO puede emitir QR → la conciliación no firmaría los pagos.
# La PÚBLICA va en la máquina (firmware); la PRIVADA solo aquí, nunca en el repo.
DSP_PRIVATE_KEY=

# --- Conciliación por correo (IMAP del buzón grabibot) ----------------------
GRABI_IMAP_HOST=imap.gmail.com
GRABI_IMAP_PORT=993
GRABI_IMAP_USER=grabibot@gmail.com
# App Password de Gmail (16 caracteres), NO la contraseña normal de la cuenta.
GRABI_IMAP_PASS=

# --- Llave Bre-B por máquina (alias de cobro mostrado al pagar, ADR-014) -----
# Formato: GRABI_BREB_KEY_<MID>. Para el piloto (M001):
GRABI_BREB_KEY_M001=

# --- Conciliación: modo de matching (opcional) ------------------------------
# Por defecto = monto exacto + nombre del pagador (ADR-018). Descomenta solo
# para volver al modo legado de "monto único":
# GRABI_MATCH_MODE=unique_amount
