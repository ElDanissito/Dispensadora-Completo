# Llaves criptográficas — la PRIVADA nunca entra al repo (regla no negociable)
.keys/
*.key
*.pem
.env
.env.*

# Binarios compilados
software/dsp
software/dsp.exe
*.exe
*.out

# Bases de datos del piloto
*.db
*.db-journal
*.sqlite
*.sqlite3

# Fotos de producto subidas por el panel admin (datos de operación, no del repo)
software/data/

# QR / imágenes generadas en pruebas locales (los vectores versionados van aparte)
*.png
!especificaciones/**/*.png

# Capturas de UI: pueden mostrar datos reales (llave/nombre) → no al repo público
especificaciones/ui-web-v1-capturas/

# Correos de alerta reales (contienen datos personales) — NUNCA al repo público
*.eml
# Excepción: fixture de test ANONIMIZADO (necesario para go test)
!software/internal/bankmail/testdata/muestra.eml

# Sistema / editor
.DS_Store
Thumbs.db
